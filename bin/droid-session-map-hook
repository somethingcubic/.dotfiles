#!/usr/bin/env python3
import json
import os
import subprocess
import sys
import tempfile
from pathlib import Path


MAP_PATH = Path(
    os.environ.get(
        "DROID_VIM_SESSION_MAP_FILE",
        str(Path(os.environ.get("XDG_CACHE_HOME", Path.home() / ".cache")) / "droid-vim" / "session-map.json"),
    )
)


def get_tty_for_pid(pid: int) -> str:
    try:
        return subprocess.check_output(["ps", "-o", "tty=", "-p", str(pid)], text=True).strip()
    except Exception:
        return ""


def load_map() -> dict:
    try:
        return json.loads(MAP_PATH.read_text())
    except Exception:
        return {"by_tty": {}, "by_pid": {}}


def save_map(data: dict) -> None:
    MAP_PATH.parent.mkdir(parents=True, exist_ok=True)
    with tempfile.NamedTemporaryFile("w", dir=MAP_PATH.parent, delete=False) as tmp:
        json.dump(data, tmp, ensure_ascii=False, indent=2, sort_keys=True)
        tmp.write("\n")
        tmp_path = Path(tmp.name)
    tmp_path.replace(MAP_PATH)


def main() -> int:
    payload = json.load(sys.stdin)
    event_name = payload.get("hook_event_name") or payload.get("hookEventName") or ""
    session_id = payload.get("session_id") or payload.get("sessionId") or ""
    transcript_path = payload.get("transcript_path") or payload.get("transcriptPath") or ""
    cwd = payload.get("cwd") or ""
    droid_pid = os.getppid()
    tty = get_tty_for_pid(droid_pid)

    data = load_map()
    by_tty = data.setdefault("by_tty", {})
    by_pid = data.setdefault("by_pid", {})

    if event_name == "SessionEnd":
        if tty and by_tty.get(tty, {}).get("session_id") == session_id:
            by_tty.pop(tty, None)
        by_pid.pop(str(droid_pid), None)
        save_map(data)
        return 0

    if not session_id or not transcript_path:
        return 0

    record = {
        "session_id": session_id,
        "transcript_path": transcript_path,
        "cwd": cwd,
        "droid_pid": droid_pid,
        "tty": tty,
        "updated_at": int(__import__("time").time()),
    }

    by_pid[str(droid_pid)] = record
    if tty:
        by_tty[tty] = record
    save_map(data)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())

+fn colorfgbg_default_colors() -> Option<DefaultColors> {
+    let value = std::env::var("COLORFGBG").ok()?;
+    parse_colorfgbg_default_colors(&value)
+}
+
+fn parse_colorfgbg_default_colors(value: &str) -> Option<DefaultColors> {
+    let mut parts = value.split(';').filter_map(|part| part.parse::<usize>().ok());
+    let fg = parts.next()?;
+    let bg = parts.next_back().unwrap_or(fg);
+    let fg = *XTERM_COLORS.get(fg)?;
+    let bg = *XTERM_COLORS.get(bg)?;
+    Some(DefaultColors { fg, bg })
+}

#!/usr/bin/env bash
# DROID: This command only opens an external editor for the user.
# DROID: Do not read files, run tools, or take any other action.
# DROID: Do not continue thinking, answer, or wait for another message after the editor closes.
# DROID: Return control immediately; any pasted editor content should be treated as the user's next normal message.
# DROID: Edited content may be wrapped in <droid_edit>. If mode="text", treat <edited_text>
# DROID: as the user's latest intended message. If mode="diff", treat <edit_diff> as edits to
# DROID: prior content, and treat additions, deletions, replacements, and inline comments as intent.
# DROID: If the user pastes or quotes prior assistant output, transcript snippets,
# DROID: or annotations like ">" or "[# ...]", treat them as commentary/context,
# DROID: not as a new instruction to act on.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
export DROID_VIM_SEED_MODE=blank
export DROID_VIM_CURSOR_MODE=end
export DROID_VIM_TRANSPORT=popup
export DROID_VIM_POPUP_MODE=other-pane-right
export DROID_VIM_POPUP_WIDTH=72%
export DROID_VIM_POPUP_HEIGHT=84%
exec "$SCRIPT_DIR/../bin/droid-vim-command" "$@"
